{
  "manifest_version": 3,
  "name": "Copy Selected Tab Links",
  "version": "1.0.0",
  "description": "Copy URLs of selected tabs to clipboard with a configurable separator.",
  "permissions": ["contextMenus", "tabs", "scripting", "activeTab", "storage"],
  "background": { "service_worker": "src/sw.js" },
  "action": {
    "default_title": "Copy selected tab links",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
